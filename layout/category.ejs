<%#

this page will judge whether current page is 'category.'
url:'http://localhost:4000/category/' return false.
url:'http://localhost:4000/categories/test/' return true.

if you enter 'category' page by click link will show all categories.
otherwise if you enter 'categories' by click post header link will show the single category of this post.

how to add a category page:

    1. hexo new page "category"
    2. cd source/category/index.md
    3. add layout pattern like this:
    ---
    title: '''category'''
    date: 2019-06-09 09:56:49
    layout: category
    ---

 %>

<%

function isDirectPost(cat, post) {
    if (!post.categories) return false;
    const cats = post.categories.toArray ? post.categories.toArray() : post.categories;
    return cats.length > 0 && cats[cats.length - 1].name === cat.name;
}

function getDirectSubCategories(cat) {
    const allCats = site.categories.toArray ? site.categories.toArray() : site.categories;
    return allCats.filter(c => c.parent === cat._id);
}

function getDirectPosts(cat) {
    return (cat.posts || []).filter(post => isDirectPost(cat, post));
}
%>

<% if (!is_category()) { %>

    <div class="container">
        <div class="post-wrap categories">
            <h2 class="post-title">-&nbsp;分类&nbsp;-</h2>
            <div class="categories-card">
                <% (site.categories.toArray ? site.categories.toArray() : site.categories).filter(c => !c.parent).forEach(cat => { %>
                    <div class="card-item">
                        <div class="categories">
                            <a href="<%- url_for(cat.path) %>">
                                <h3>
                                    <i class="iconfont icon-category" style="padding-right:3px"></i>
                                    <%- cat.name %>
                                </h3>
                            </a>
                            <% const subCats = getDirectSubCategories(cat); %>
                            <% if (subCats.length > 0) { %>
                                <div class="sub-category-wrap">
                                    <% subCats.forEach(subCat => { %>
                                        <a class="sub-category-link" href="<%- url_for(subCat.path) %>">
                                            <i class="iconfont icon-category"></i><%- subCat.name %>
                                        </a>
                                    <% }); %>
                                </div>
                            <% } %>
                            <% const directPosts = getDirectPosts(cat); %>
                            <% directPosts.forEach((post_item, index = 0) => { %>
                                <% if (++index <= 5) { %>
                                    <article class="archive-item">
                                        <a class="archive-item-link"
                                           href="<%- url_for(post_item.path) %>"><%- post_item.title %></a>
                                    </article>
                                <% } %>
                            <% }); %>
                            <% if (directPosts.length > 5) { %>
                                <a class="more-post-link" href="<%- url_for(cat.path) %>">更多>></a>
                            <% } %>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>
    </div>

<% } else { %>

    <%- partial('_page/category', {pagination: config.category, index: true}) %>

<% } %>
