<div class="toc-mobile-fab" onclick="toggleMobileToc()">
  <span class="toc-mobile-icon">☰</span>
</div>

<div class="toc-mobile-overlay" onclick="toggleMobileToc()"></div>

<div class="toc-mobile-drawer">
  <div class="toc-mobile-header">
    <span class="toc-mobile-title">目录</span>
  </div>
  <div class="tocbot-list-mobile"></div>
</div>

<script>
  var tocbot_timer_mobile;
  var DEPTH_MAX = 6;
  var tocbot_mobile_config = {
    tocSelector: '.tocbot-list-mobile',
    contentSelector: '.post-content',
    headingSelector: 'h1, h2, h3, h4, h5',
    orderedList: false,
    scrollSmooth: true,
    onClick: extend_click_mobile,
  };

  function extend_click_mobile() {
    clearTimeout(tocbot_timer_mobile);
    tocbot_timer_mobile = setTimeout(function() {
      tocbot.refresh(obj_merge_mobile(tocbot_mobile_config, {
        hasInnerContainers: true
      }));
    }, 420);
  }

  document.ready(function() {
    tocbot.init(obj_merge_mobile(tocbot_mobile_config, {
      collapseDepth: 1
    }));
  });

  function obj_merge_mobile(target, source) {
    for (var item in source) {
      if (source.hasOwnProperty(item)) {
        target[item] = source[item];
      }
    }
    return target;
  }

  function toggleMobileToc() {
    var overlay = document.querySelector('.toc-mobile-overlay');
    var drawer = document.querySelector('.toc-mobile-drawer');
    var fab = document.querySelector('.toc-mobile-fab');
    
    if (overlay.classList.contains('active')) {
      overlay.classList.remove('active');
      drawer.classList.remove('active');
      fab.classList.remove('active');
      document.body.style.overflow = '';
    } else {
      overlay.classList.add('active');
      drawer.classList.add('active');
      fab.classList.add('active');
      document.body.style.overflow = 'hidden';
    }
  }
</script>