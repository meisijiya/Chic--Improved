.post-wrap
  .categories-card
    margin 0 auto
    margin-top 1em
    display flex
    align-items center
    justify-content space-between
    flex-direction row
    flex-wrap wrap
    padding 0 2.5em
    line-height 1.6em
    .card-item
      font-size 14px
      text-align left
      width 45%
      display flex
      align-items flex-start
      margin-top 2em
      min-height 16em
      padding 0 2%
      position relative
      .categories
        overflow hidden
        .sub-category-wrap
          display flex
          flex-wrap wrap
          align-items center
          margin-bottom 0.8em
          padding-bottom 0.5em
          border-bottom 1px dashed #eee
          gap 0.5em
          .sub-category-link
            display inline-flex
            align-items center
            font-size 13px
            color #666
            text-decoration none
            padding 0.2em 0.6em
            border-radius 4px
            background #f5f5f5
            transition all 0.2s ease
            margin-left 1.5em
            .iconfont
              font-size 12px
              margin-right 0.3em
              color #888
            &:hover
              background #e8e8e8
              color #333
              .iconfont
                color #555
            .dark-theme &
              background #2a2a2a
              color #aaa
              .iconfont
                color #777
              &:hover
                background #3a3a3a
                color #fff
                .iconfont
                  color #ccc

.categories-list
  .sub-categories-section
    display flex
    flex-wrap wrap
    align-items center
    margin-bottom 1.5em
    padding-bottom 1em
    border-bottom 1px solid #eee
    gap 0.8em
    .sub-category-item
      display inline-flex
      align-items center
      font-size 15px
      color #555
      text-decoration none
      padding 0.3em 0.8em
      background #f5f5f5
      border-radius 4px
      transition all 0.2s ease
      .iconfont
        font-size 14px
        margin-right 0.4em
        color #777
      &:hover
        background #e8e8e8
        color #333
      .dark-theme &
        background #2a2a2a
        color #aaa
        .iconfont
          color #777
        &:hover
          background #3a3a3a
          color #fff

@media screen and (max-width: 768px)
  .post-wrap
    .categories-card
      padding 0 1em
      .card-item
        width 100%
        min-height 0
        margin-top 1.5em
        .categories
          .sub-category-wrap
            gap 0.4em
            .sub-category-link
              font-size 12px
              padding 0.15em 0.5em

  .categories-list
    .sub-categories-section
      gap 0.5em
      .sub-category-item
        font-size 14px
        padding 0.2em 0.6em

.categories-list
  .archive
    .empty-tip
      text-align center
      color #999
      padding 2em 0
      font-size 14px
      .dark-theme &
        color #666
